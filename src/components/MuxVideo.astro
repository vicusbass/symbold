---
interface Props {
  playbackId: string;
  videoTitle?: string;
  aspectRatio?: string;
  class?: string;
}

const { playbackId, aspectRatio = '16:9', class: className } = Astro.props;
const cssAspectRatio = aspectRatio.replace(':', '/');
const posterUrl = `https://image.mux.com/${playbackId}/thumbnail.webp?width=1920&fit_mode=preserve`;
---

<div
  class:list={['w-full overflow-hidden', className]}
  style={`aspect-ratio: ${cssAspectRatio}; background-color: #111; background-image: url('${posterUrl}'); background-size: cover; background-position: center;`}
>
  <mux-video
    playback-id={playbackId}
    muted
    autoplay
    loop
    playsinline
    disable-cookies
    disable-tracking
    rendition-order="desc"
    class="mux-video h-full w-full"
    style="--media-object-fit: cover;"
    data-mux-video
  ></mux-video>
</div>

<script>
  function initMuxVideos() {
    document.querySelectorAll<HTMLMediaElement>('[data-mux-video]').forEach((player) => {
      if (player.dataset.muxVideoInit) return;
      player.dataset.muxVideoInit = 'true';
      const reveal = () => player.classList.add('is-playing');
      if (!player.paused) {
        reveal();
      } else {
        player.addEventListener('playing', reveal, { once: true });
      }
    });
  }

  initMuxVideos();
  document.addEventListener('astro:page-load', initMuxVideos);

  // Load mux-video asynchronously so it doesn't block the main JS bundle.
  // The custom element upgrade fires 'playing' on any already-attached listeners.
  import('@mux/mux-video').then(() => initMuxVideos());
</script>

<style>
  [data-mux-video] {
    display: block;
    opacity: 0;
    transition: opacity 700ms ease-out;
  }

  [data-mux-video].is-playing {
    opacity: 1;
  }
</style>
