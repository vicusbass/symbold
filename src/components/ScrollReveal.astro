---
interface Props {
  delay?: number;
  class?: string;
  delayed?: boolean;
}

const { delay = 600, class: className = '', delayed = false } = Astro.props;
---

<div
  class={`fade-in-scroll ${className}`}
  data-scroll-animation
  data-delay={delay}
  data-delayed={delayed}
>
  <slot />
</div>

<script>
  let scrollObserver: IntersectionObserver | null = null;

  function initScrollReveal() {
    if (scrollObserver) {
      scrollObserver.disconnect();
    }

    scrollObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.getAttribute('data-delay') || '600');
            const delayed = entry.target.getAttribute('data-delayed') === 'true';
            const extraDelay = delayed && window.innerWidth > 768 ? delay : 0;
            setTimeout(() => {
              if (!entry.target.classList.contains('visible')) entry.target.classList.add('visible');
            }, extraDelay);
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px' }
    );

    document.querySelectorAll('[data-scroll-animation]').forEach((el) => {
      scrollObserver!.observe(el);
    });
  }

  // Initialize immediately — module scripts are deferred so DOM is ready,
  // but they run before DOMContentLoaded, avoiding the Safari delay where
  // astro:page-load fires late due to the mux-video bundle taking longer.
  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
